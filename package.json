{
  "name": "tomatodev",
  "version": "1.0.0",
  "type": "module",
  "description": "Development Pages mirror for Tomato Farm",
  "main": "app.js",
  "scripts": {
    "test": "node scripts/check-project-governance.mjs && node scripts/check-runtime-syntax.mjs && node --test",
    "check:governance": "node scripts/check-project-governance.mjs",
    "check:syntax": "node scripts/check-runtime-syntax.mjs",
    "test:contracts": "node scripts/run-test-suite.mjs contracts",
    "test:smoke": "node scripts/run-test-suite.mjs smoke",
    "test:workout": "node scripts/run-test-suite.mjs workout",
    "test:data": "node scripts/run-test-suite.mjs data",
    "test:ui": "node scripts/run-test-suite.mjs ui",
    "test:list": "node scripts/run-test-suite.mjs --list",
    "start": "node tools/api-server.js",
    "dev": "node scripts/dev-start.mjs",
    "bump": "node scripts/bump-cache.js",
    "build": "node scripts/generate-style-entry.mjs && node scripts/bump-cache.js && node scripts/generate-build-info.mjs && node scripts/copy-www.js",
    "cap:sync": "npm run build && npx cap sync android",
    "build:mobile-apk": "node scripts/build-mobile-apk.mjs",
    "cap:open": "npx cap open android",
    "server": "node tools/api-server.js",
    "audit:ai-diet": "node scripts/audit-ai-diet-account.mjs",
    "verify:assets": "node scripts/generate-style-entry.mjs --check && node scripts/verify-runtime-assets.mjs",
    "verify:deploy": "node scripts/verify-deploy.mjs",
    "verify:deployed-markers": "node scripts/verify-deployed-markers.mjs",
    "check:repository": "node scripts/check-repository-boundary.mjs && node scripts/check-project-governance.mjs",
    "setup:repository": "node scripts/install-repository-guard.mjs && node scripts/check-repository-boundary.mjs",
    "deploy:dev": "node scripts/deploy-development.mjs",
    "verify:rom-graph": "node scripts/verify-rom-live-graph.mjs",
    "verify:workout": "node scripts/verify-workout-fixture.mjs",
    "verify:wear-refresh": "node scripts/verify-wear-refresh-adb.mjs",
    "install:wear-pair": "node scripts/verify-wear-refresh-adb.mjs --mode install",
    "install:wear-watch": "node scripts/verify-wear-refresh-adb.mjs --mode install-watch"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "express": "^4.21.0",
    "firebase": "^12.11.0",
    "puppeteer": "^24.40.0"
  },
  "engines": {
    "node": "24.x"
  },
  "devDependencies": {
    "@seed-design/icon": "^0.6.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2"
  }
}
