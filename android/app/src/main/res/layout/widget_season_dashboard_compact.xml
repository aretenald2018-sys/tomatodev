<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:id="@+id/widget_root" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/widget_bg" android:orientation="vertical" android:padding="13dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/widget_season_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="운동 시즌" android:textColor="@color/widget_text" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_season_meta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W1" android:textColor="@color/widget_secondary" android:textSize="9sp" />
        </LinearLayout>
        <TextView android:id="@+id/widget_refresh" android:layout_width="48dp" android:layout_height="48dp" android:gravity="center" android:text="↻" android:textColor="@color/widget_secondary" android:textSize="20sp" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:id="@+id/widget_streak" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🔥 0일 연속" android:textColor="@color/widget_text" android:textSize="21sp" android:textStyle="bold" />
        <TextView android:id="@+id/widget_today_state" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="오늘 기록 전" android:textColor="@color/widget_accent" android:textSize="9sp" android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
        <TextView android:id="@+id/widget_day_1" style="@style/SeasonWidgetDayCompact" android:text="○" /><TextView android:id="@+id/widget_day_2" style="@style/SeasonWidgetDayCompact" android:text="○" /><TextView android:id="@+id/widget_day_3" style="@style/SeasonWidgetDayCompact" android:text="○" /><TextView android:id="@+id/widget_day_4" style="@style/SeasonWidgetDayCompact" android:text="○" /><TextView android:id="@+id/widget_day_5" style="@style/SeasonWidgetDayCompact" android:text="○" /><TextView android:id="@+id/widget_day_6" style="@style/SeasonWidgetDayCompact" android:text="○" /><TextView android:id="@+id/widget_day_7" style="@style/SeasonWidgetDayCompact" android:text="○" />
    </LinearLayout>
    <LinearLayout android:id="@+id/widget_running_card" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="6dp" android:layout_weight="1" android:background="@drawable/widget_panel_bg" android:orientation="vertical" android:padding="9dp">
        <TextView android:id="@+id/widget_running_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="러닝 0 / 20 km" android:textColor="@color/widget_text" android:textSize="12sp" android:textStyle="bold" />
        <ProgressBar android:id="@+id/widget_running_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="5dp" android:max="100" android:progressBackgroundTint="@color/widget_track" android:progressTint="@color/widget_accent" />
        <TextView android:id="@+id/widget_running_detail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:maxLines="1" android:text="0 / 3회 · 기준 수집 중" android:textColor="@color/widget_secondary" android:textSize="8sp" />
    </LinearLayout>
    <LinearLayout android:id="@+id/widget_strength_card" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="6dp" android:layout_weight="1" android:background="@drawable/widget_panel_bg" android:orientation="vertical" android:padding="9dp">
        <TextView android:id="@+id/widget_strength_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="헬스 계획 0 / 3" android:textColor="@color/widget_text" android:textSize="12sp" android:textStyle="bold" />
        <ProgressBar android:id="@+id/widget_strength_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="5dp" android:max="100" android:progressBackgroundTint="@color/widget_track" android:progressTint="@color/widget_success" />
        <TextView android:id="@+id/widget_strength_detail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:maxLines="1" android:text="볼륨·1RM 기준 수집 중" android:textColor="@color/widget_secondary" android:textSize="8sp" />
    </LinearLayout>
    <LinearLayout android:id="@+id/widget_next_section" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"><TextView android:id="@+id/widget_next_plan" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="다음 계획" /></LinearLayout>
    <TextView android:id="@+id/widget_sync_time" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="end" android:text="동기화 대기" android:textColor="@color/widget_muted" android:textSize="7sp" />
</LinearLayout>
