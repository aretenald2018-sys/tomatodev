<?xml version="1.0" encoding="utf-8"?>
<!-- 작게 붙였을 때(높이 300dp 미만) 쓰는 축약본. 글자 크기는 전체 레이아웃과
     같은 기준(본문 10sp 이상)을 지키는 대신 근력 카드를 접고 식단/러닝만 남긴다.
     접힌 뷰도 id는 남겨 둬야 SeasonDashboardWidget이 그대로 렌더링할 수 있다. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_season_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="오늘/이번 주 요약"
                android:textColor="@color/widget_text"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_season_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="운동 시즌 · W1"
                android:textColor="@color/widget_secondary"
                android:textSize="10sp" />
        </LinearLayout>
        <TextView
            android:id="@+id/widget_refresh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="위젯 새로고침"
            android:gravity="center"
            android:text="↻"
            android:textColor="@color/widget_secondary"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_diet_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1.35"
        android:background="@drawable/widget_panel_bg"
        android:orientation="vertical"
        android:padding="8dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="오늘 식단"
                android:textColor="@color/widget_text"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_diet_meals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_pill_bg"
                android:paddingStart="7dp"
                android:paddingTop="2dp"
                android:paddingEnd="7dp"
                android:paddingBottom="2dp"
                android:text="기록한 식사 0회"
                android:textColor="@color/widget_secondary"
                android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ProgressBar
                    android:id="@+id/widget_diet_progress"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:indeterminateOnly="false"
                    android:max="100"
                    android:progressDrawable="@drawable/widget_ring_progress" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/widget_diet_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/widget_text"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/widget_diet_kcal_target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 2,500 kcal"
                        android:textColor="@color/widget_secondary"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/widget_diet_kcal_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/widget_success"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:id="@+id/widget_diet_macros"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:text=""
                    android:visibility="gone" />
            </FrameLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.15"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="탄수화물"
                        android:textColor="@color/widget_text"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/widget_diet_carbs_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 220 g"
                        android:textColor="@color/widget_secondary"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/widget_diet_carbs_percent"
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0%"
                        android:textColor="@color/widget_success"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/widget_diet_carbs_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="3dp"
                    android:max="100"
                    android:progressBackgroundTint="@color/widget_track"
                    android:progressTint="@color/widget_success" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="단백질"
                        android:textColor="@color/widget_text"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/widget_diet_protein_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 160 g"
                        android:textColor="@color/widget_secondary"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/widget_diet_protein_percent"
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0%"
                        android:textColor="@color/widget_purple"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/widget_diet_protein_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="3dp"
                    android:max="100"
                    android:progressBackgroundTint="@color/widget_track"
                    android:progressTint="@color/widget_purple" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="지방"
                        android:textColor="@color/widget_text"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/widget_diet_fat_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 60 g"
                        android:textColor="@color/widget_secondary"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/widget_diet_fat_percent"
                        android:layout_width="38dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0%"
                        android:textColor="@color/widget_orange"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/widget_diet_fat_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="3dp"
                    android:max="100"
                    android:progressBackgroundTint="@color/widget_track"
                    android:progressTint="@color/widget_orange" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_running_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1"
        android:background="@drawable/widget_panel_bg"
        android:orientation="vertical"
        android:padding="8dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="이번 주 러닝"
                android:textColor="@color/widget_text"
                android:textSize="12sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_running_improvement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_improvement_bg"
                android:paddingStart="7dp"
                android:paddingTop="2dp"
                android:paddingEnd="7dp"
                android:paddingBottom="2dp"
                android:text="페이스 개선 —"
                android:textColor="@color/widget_success"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="3dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/widget_running_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="평균 페이스 (km당)"
                    android:textColor="@color/widget_secondary"
                    android:textSize="10sp" />
                <TextView
                    android:id="@+id/widget_running_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="7'44&quot;/km"
                    android:textColor="@color/widget_blue"
                    android:textSize="19sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_running_last"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="이전 8'09&quot;/km"
                    android:textColor="@color/widget_secondary"
                    android:textSize="10sp" />
            </LinearLayout>
            <ImageView
                android:id="@+id/widget_running_chart"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.3"
                android:contentDescription="최근 러닝 페이스 추이"
                android:scaleType="fitXY"
                android:src="@drawable/widget_run_chart" />
        </LinearLayout>
        <TextView
            android:id="@+id/widget_running_detail"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text=""
            android:visibility="gone" />
        <ProgressBar
            android:id="@+id/widget_running_progress"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_strength_card"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView
            android:id="@+id/widget_strength_value"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="" />
        <TextView
            android:id="@+id/widget_strength_check_1"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="" />
        <TextView
            android:id="@+id/widget_strength_check_2"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="" />
        <TextView
            android:id="@+id/widget_strength_check_3"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="" />
        <TextView
            android:id="@+id/widget_strength_check_4"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="" />
        <TextView
            android:id="@+id/widget_strength_check_5"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="" />
        <ProgressBar
            android:id="@+id/widget_strength_progress"
            android:layout_width="1dp"
            android:layout_height="1dp" />
        <TextView
            android:id="@+id/widget_strength_detail"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_sync_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:gravity="end"
        android:text="동기화 대기"
        android:textColor="@color/widget_muted"
        android:textSize="10sp" />
</LinearLayout>
