<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/widget_season_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="운동 시즌" android:textColor="@color/widget_text" android:textSize="17sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_season_meta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="W1 · 84일 남음" android:textColor="@color/widget_secondary" android:textSize="10sp" />
        </LinearLayout>
        <TextView android:id="@+id/widget_refresh" android:layout_width="48dp" android:layout_height="48dp" android:gravity="center" android:text="↻" android:textColor="@color/widget_secondary" android:textSize="22sp" android:contentDescription="위젯 새로고침" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:id="@+id/widget_streak" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🔥 0일 연속" android:textColor="@color/widget_text" android:textSize="26sp" android:textStyle="bold" />
        <TextView android:id="@+id/widget_today_state" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/widget_panel_bg" android:paddingLeft="9dp" android:paddingTop="6dp" android:paddingRight="9dp" android:paddingBottom="6dp" android:text="오늘 기록 전" android:textColor="@color/widget_accent" android:textSize="10sp" android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center" android:orientation="horizontal">
        <TextView android:id="@+id/widget_day_1" style="@style/SeasonWidgetDay" android:text="○" />
        <TextView android:id="@+id/widget_day_2" style="@style/SeasonWidgetDay" android:text="○" />
        <TextView android:id="@+id/widget_day_3" style="@style/SeasonWidgetDay" android:text="○" />
        <TextView android:id="@+id/widget_day_4" style="@style/SeasonWidgetDay" android:text="○" />
        <TextView android:id="@+id/widget_day_5" style="@style/SeasonWidgetDay" android:text="○" />
        <TextView android:id="@+id/widget_day_6" style="@style/SeasonWidgetDay" android:text="○" />
        <TextView android:id="@+id/widget_day_7" style="@style/SeasonWidgetDay" android:text="○" />
    </LinearLayout>

    <LinearLayout android:id="@+id/widget_running_card" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="10dp" android:layout_weight="1" android:background="@drawable/widget_panel_bg" android:gravity="center_vertical" android:minHeight="82dp" android:orientation="vertical" android:padding="12dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="러닝" android:textColor="@color/widget_secondary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_running_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 / 20 km" android:textColor="@color/widget_text" android:textSize="15sp" android:textStyle="bold" />
        </LinearLayout>
        <ProgressBar android:id="@+id/widget_running_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="8dp" android:max="100" android:progress="0" android:progressBackgroundTint="@color/widget_track" android:progressTint="@color/widget_accent" />
        <TextView android:id="@+id/widget_running_detail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:text="0 / 3회 · 기준 수집 중" android:textColor="@color/widget_secondary" android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout android:id="@+id/widget_strength_card" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="9dp" android:layout_weight="1" android:background="@drawable/widget_panel_bg" android:gravity="center_vertical" android:minHeight="82dp" android:orientation="vertical" android:padding="12dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="헬스" android:textColor="@color/widget_secondary" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/widget_strength_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="계획 0 / 3" android:textColor="@color/widget_text" android:textSize="15sp" android:textStyle="bold" />
        </LinearLayout>
        <ProgressBar android:id="@+id/widget_strength_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="8dp" android:max="100" android:progress="0" android:progressBackgroundTint="@color/widget_track" android:progressTint="@color/widget_success" />
        <TextView android:id="@+id/widget_strength_detail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:text="볼륨 기준 수집 중 · 1RM 기준 수집 중" android:textColor="@color/widget_secondary" android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout android:id="@+id/widget_next_section" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="9dp" android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="다음 계획" android:textColor="@color/widget_muted" android:textSize="9sp" android:textStyle="bold" />
        <TextView android:id="@+id/widget_next_plan" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:maxLines="1" android:ellipsize="end" android:text="스쿼트 · 러닝 5km" android:textColor="@color/widget_text" android:textSize="11sp" android:textStyle="bold" />
    </LinearLayout>
    <TextView android:id="@+id/widget_sync_time" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:gravity="end" android:text="동기화 대기" android:textColor="@color/widget_muted" android:textSize="8sp" />
</LinearLayout>
