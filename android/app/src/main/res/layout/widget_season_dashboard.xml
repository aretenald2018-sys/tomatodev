<?xml version="1.0" encoding="utf-8"?>
<!-- 홈 화면에서 맨눈으로 읽혀야 하므로 본문은 10sp 아래로 내리지 않는다.
     크기를 키운 대신 카드는 식단/근력/러닝 3개로 줄이고, 러닝 카드는
     날짜·평균 페이스가 찍힌 추이 그래프를 오른쪽에 가로로 넓게 둔다. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_season_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="오늘/이번 주 요약"
                android:textColor="@color/widget_text"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_season_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="운동 시즌 · W1"
                android:textColor="@color/widget_secondary"
                android:textSize="11sp" />
        </LinearLayout>
        <TextView
            android:id="@+id/widget_refresh"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:contentDescription="위젯 새로고침"
            android:gravity="center"
            android:text="↻"
            android:textColor="@color/widget_secondary"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_diet_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1.3"
        android:background="@drawable/widget_panel_bg"
        android:orientation="vertical"
        android:padding="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="오늘 식단"
                android:textColor="@color/widget_text"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_diet_meals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_pill_bg"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:text="기록한 식사 0회"
                android:textColor="@color/widget_secondary"
                android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ProgressBar
                    android:id="@+id/widget_diet_progress"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_gravity="center"
                    android:indeterminateOnly="false"
                    android:max="100"
                    android:progressDrawable="@drawable/widget_ring_progress" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="섭취 칼로리"
                        android:textColor="@color/widget_secondary"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/widget_diet_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/widget_text"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/widget_diet_kcal_target"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 2,500 kcal"
                        android:textColor="@color/widget_secondary"
                        android:textSize="10sp" />
                    <TextView
                        android:id="@+id/widget_diet_kcal_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/widget_success"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:id="@+id/widget_diet_macros"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:text=""
                    android:visibility="gone" />
            </FrameLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.25"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="탄수화물"
                        android:textColor="@color/widget_text"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/widget_diet_carbs_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 220 g"
                        android:textColor="@color/widget_secondary"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/widget_diet_carbs_percent"
                        android:layout_width="42dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0%"
                        android:textColor="@color/widget_success"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/widget_diet_carbs_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="4dp"
                    android:max="100"
                    android:progressBackgroundTint="@color/widget_track"
                    android:progressTint="@color/widget_success" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="단백질"
                        android:textColor="@color/widget_text"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/widget_diet_protein_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 160 g"
                        android:textColor="@color/widget_secondary"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/widget_diet_protein_percent"
                        android:layout_width="42dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0%"
                        android:textColor="@color/widget_purple"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/widget_diet_protein_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="4dp"
                    android:max="100"
                    android:progressBackgroundTint="@color/widget_track"
                    android:progressTint="@color/widget_purple" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="지방"
                        android:textColor="@color/widget_text"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/widget_diet_fat_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 60 g"
                        android:textColor="@color/widget_secondary"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/widget_diet_fat_percent"
                        android:layout_width="42dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="0%"
                        android:textColor="@color/widget_orange"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <ProgressBar
                    android:id="@+id/widget_diet_fat_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="4dp"
                    android:max="100"
                    android:progressBackgroundTint="@color/widget_track"
                    android:progressTint="@color/widget_orange" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_strength_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1.25"
        android:background="@drawable/widget_panel_bg"
        android:orientation="vertical"
        android:padding="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="이번 주 근력 목표"
                android:textColor="@color/widget_text"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_strength_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 5 목표 달성"
                android:textColor="@color/widget_text"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
        <TextView
            android:id="@+id/widget_strength_check_1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="○ 다음 목표"
            android:textColor="@color/widget_muted"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/widget_strength_check_2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="○ 다음 목표"
            android:textColor="@color/widget_muted"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/widget_strength_check_3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="○ 다음 목표"
            android:textColor="@color/widget_muted"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/widget_strength_check_4"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="○ 다음 목표"
            android:textColor="@color/widget_muted"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/widget_strength_check_5"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="○ 다음 목표"
            android:textColor="@color/widget_muted"
            android:textSize="12sp" />
        <ProgressBar
            android:id="@+id/widget_strength_progress"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />
        <TextView
            android:id="@+id/widget_strength_detail"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text=""
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_running_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1.05"
        android:background="@drawable/widget_panel_bg"
        android:orientation="vertical"
        android:padding="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="이번 주 러닝"
                android:textColor="@color/widget_text"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_running_improvement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_improvement_bg"
                android:paddingStart="9dp"
                android:paddingTop="3dp"
                android:paddingEnd="9dp"
                android:paddingBottom="3dp"
                android:text="페이스 개선 —"
                android:textColor="@color/widget_success"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/widget_running_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="평균 페이스 (km당)"
                    android:textColor="@color/widget_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/widget_running_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="7'44&quot;/km"
                    android:textColor="@color/widget_blue"
                    android:textSize="24sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/widget_running_last"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="이전 8'09&quot;/km"
                    android:textColor="@color/widget_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
            <ImageView
                android:id="@+id/widget_running_chart"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.4"
                android:contentDescription="최근 러닝 페이스 추이"
                android:scaleType="fitXY"
                android:src="@drawable/widget_run_chart" />
        </LinearLayout>
        <TextView
            android:id="@+id/widget_running_detail"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text=""
            android:visibility="gone" />
        <ProgressBar
            android:id="@+id/widget_running_progress"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_sync_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="end"
        android:text="동기화 대기"
        android:textColor="@color/widget_muted"
        android:textSize="10sp" />
</LinearLayout>
