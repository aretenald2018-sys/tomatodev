<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/tomato_dashboard_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="14dp">
    <TextView
        android:id="@+id/tomato_dashboard_kicker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="나를 위한 하루"
        android:textColor="@color/widget_accent"
        android:textSize="12sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/tomato_dashboard_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="오늘 상태"
        android:textColor="@color/widget_text"
        android:textSize="23sp"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/tomato_dashboard_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="오늘 상태 요약"
        android:textColor="@color/widget_secondary"
        android:textSize="12sp" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:orientation="horizontal">
        <LinearLayout
            android:id="@+id/tomato_dashboard_food_root"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/widget_panel_bg"
            android:orientation="vertical"
            android:padding="11dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="일일 음식 섭취" android:textColor="@color/widget_text" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tomato_dashboard_food_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:ellipsize="end" android:maxLines="1" android:text="연결 대기" android:textColor="@color/widget_text" android:textSize="16sp" android:textStyle="bold" />
            <ProgressBar android:id="@+id/tomato_dashboard_food_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="8dp" android:max="100" android:progress="0" android:progressBackgroundTint="@color/widget_track" android:progressTint="@color/widget_accent" />
            <TextView android:id="@+id/tomato_dashboard_food_detail" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:ellipsize="end" android:maxLines="2" android:text="식단 데이터 필요" android:textColor="@color/widget_secondary" android:textSize="12sp" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/tomato_dashboard_strength_root"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:background="@drawable/widget_panel_bg"
            android:orientation="vertical"
            android:padding="11dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="주간 헬스 목표" android:textColor="@color/widget_text" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tomato_dashboard_strength_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:ellipsize="end" android:maxLines="1" android:text="시즌 목표를 설정해 주세요" android:textColor="@color/widget_text" android:textSize="14sp" android:textStyle="bold" />
            <ProgressBar android:id="@+id/tomato_dashboard_strength_progress" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="5dp" android:layout_marginTop="8dp" android:max="100" android:progress="0" android:progressBackgroundTint="@color/widget_track" android:progressTint="@color/widget_success" />
            <TextView android:id="@+id/tomato_dashboard_strength_items" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="7dp" android:layout_weight="1" android:ellipsize="end" android:maxLines="5" android:text="시즌 목표를 설정해 주세요" android:textColor="@color/widget_secondary" android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/tomato_dashboard_running_root"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/widget_panel_bg"
        android:orientation="vertical"
        android:padding="11dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="러닝 · 최근 5회 기록" android:textColor="@color/widget_text" android:textSize="14sp" android:textStyle="bold" />
        <TextView android:id="@+id/tomato_dashboard_running_summary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="최근 러닝 기록 없음" android:textColor="@color/widget_secondary" android:textSize="12sp" />
        <TextView android:id="@+id/tomato_dashboard_running_records" android:layout_width="match_parent" android:layout_height="0dp" android:layout_marginTop="5dp" android:layout_weight="1" android:ellipsize="end" android:maxLines="5" android:text="러닝을 기록하면 최근 5회가 여기에 표시됩니다" android:textColor="@color/widget_text" android:textSize="12sp" />
    </LinearLayout>
    <TextView
        android:id="@+id/tomato_dashboard_sync"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:gravity="end"
        android:text="동기화 대기"
        android:textColor="@color/widget_muted"
        android:textSize="10sp" />
</LinearLayout>
