<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/runReadyScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="런닝"
            android:textColor="#F4F7FF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="시간 · 거리 · 심박수"
            android:textColor="#7C8499"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/runStartButton"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/wear_cardio_circle_primary"
            android:gravity="center"
            android:text="시작"
            android:textColor="#06120C"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/runActiveScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:visibility="gone">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/runMetricPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/runActiveElapsed"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="00:00" />

            <TextView
                android:id="@+id/runActiveDistance"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="0.00 킬로미터" />

            <TextView
                android:id="@+id/runActivePace"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="-- 페이스" />

            <TextView
                android:id="@+id/runActiveHeartRate"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="-- bpm 심박수" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:gravity="center_vertical|end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/runMetricPageIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="1"
                    android:text="요약 · 1/5"
                    android:textColor="#C8CFDE"
                    android:textSize="8sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/runActiveGpsStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="1"
                    android:text="GPS 준비 중"
                    android:textColor="#7C8499"
                    android:textSize="9sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/runPauseButton"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/wear_cardio_circle_muted"
                android:contentDescription="러닝 기록 일시정지"
                android:gravity="center"
                android:text="II"
                android:textColor="#D6DAE6"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/runPausedScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="일시정지"
            android:textColor="#D6DAE6"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/runPausedElapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="00:00"
            android:textColor="#F4F7FF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/runFinalStopButton"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/wear_cardio_circle_stop"
                android:gravity="center"
                android:text="종료"
                android:textColor="#F4F7FF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/runResumeButton"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/wear_cardio_circle_primary"
                android:gravity="center"
                android:text="계속"
                android:textColor="#06120C"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/runSummaryScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingTop="0dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="런닝 저장"
            android:textColor="#D6DAE6"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/runSummaryDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="0.00 km"
            android:textColor="#F4F7FF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/runSummaryDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="00:00"
            android:textColor="#D6DAE6"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/runSummaryPace"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="--"
                android:textColor="#F4F7FF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/runSummaryHeartRate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="-- bpm"
                android:textColor="#F4F7FF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/runSummaryGpsStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:text="GPS 대기"
            android:textColor="#7C8499"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/runSummarySyncStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:text=""
            android:textColor="#10B981"
            android:textSize="7sp" />

        <TextView
            android:id="@+id/runSummaryDoneButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/wear_cardio_circle_primary"
            android:gravity="center"
            android:text="완료"
            android:textColor="#06120C"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
