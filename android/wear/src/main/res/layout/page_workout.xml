<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050706"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/runReadyScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.14"
            android:text="OUTDOOR RUN"
            android:textColor="#D7FF3F"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:fontFamily="sans-serif-condensed"
            android:text="러닝"
            android:textColor="#F7F8F4"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/runReadyGpsStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="바로 시작할 수 있어요"
            android:textColor="#81877D"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/runStartButton"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/wear_cardio_circle_primary"
            android:gravity="center"
            android:text="시작"
            android:textColor="#06120C"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/runActiveScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:visibility="gone">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/runMetricPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/runActiveElapsed"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="00:00" />

            <TextView
                android:id="@+id/runActiveDistance"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="0.00 킬로미터" />

            <TextView
                android:id="@+id/runActivePace"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="-- 페이스" />

            <TextView
                android:id="@+id/runActiveHeartRate"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="-- bpm 심박수" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_gravity="bottom"
            android:background="@drawable/wear_run_footer_scrim"
            android:elevation="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:gravity="center_vertical|end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/runMetricPageIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="1"
                    android:text="요약  ● ○ ○ ○ ○"
                    android:textColor="#F7F8F4"
                    android:textSize="8sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/runActiveGpsStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="1"
                    android:text="경로 자동 기록"
                    android:textColor="#81877D"
                    android:textSize="8sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/runPauseButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/wear_cardio_circle_muted"
                android:clickable="true"
                android:contentDescription="러닝 기록 일시정지"
                android:focusable="true"
                android:gravity="center"
                android:text="II"
                android:textColor="#F7F8F4"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/runPausedScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:text="RUN PAUSED"
            android:textColor="#D7FF3F"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/runPausedElapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:fontFamily="sans-serif-condensed"
            android:text="00:00"
            android:textColor="#F7F8F4"
            android:textSize="32sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/runFinalStopButton"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/wear_cardio_circle_stop"
                android:gravity="center"
                android:text="종료"
                android:textColor="#F7F8F4"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/runResumeButton"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/wear_cardio_circle_primary"
                android:gravity="center"
                android:text="계속"
                android:textColor="#06120C"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/runSummaryScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="0dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/runSummaryDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:text="0.00 km"
            android:textColor="#F7F8F4"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/runSummaryDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="00:00"
            android:textColor="#A5ABA1"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/runSummaryPace"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="--"
                android:textColor="#D7FF3F"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/runSummaryHeartRate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="-- bpm"
                android:textColor="#FF775F"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/runSummaryGpsStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="경로 없이 저장됨"
            android:textColor="#81877D"
            android:textSize="8sp" />

        <TextView
            android:id="@+id/runSummarySyncStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textColor="#D7FF3F"
            android:textSize="8sp" />

        <TextView
            android:id="@+id/runSummaryDoneButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="7dp"
            android:background="@drawable/wear_cardio_circle_primary"
            android:gravity="center"
            android:text="완료"
            android:textColor="#06120C"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/runAmbientScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/runAmbientElapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:text="00:00"
            android:textColor="#B7BBB4"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/runAmbientLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="러닝 기록 중"
            android:textColor="#747A72"
            android:textSize="9sp" />
    </LinearLayout>
</FrameLayout>
