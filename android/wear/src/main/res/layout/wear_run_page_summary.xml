<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingEnd="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="런닝"
        android:textColor="#7C8499"
        android:textSize="9sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/runSummaryPageDistance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:text="0.00 km"
        android:textColor="#FFD84D"
        android:textSize="25sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/runSummaryPageDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:includeFontPadding="false"
        android:text="00:00"
        android:textColor="#5CB7FF"
        android:textSize="21sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/runSummaryPagePace"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:includeFontPadding="false"
        android:text="-- /km"
        android:textColor="#56F0D2"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/runSummaryPageCalories"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:includeFontPadding="false"
        android:text="-- kcal"
        android:textColor="#FF7AB6"
        android:textSize="17sp"
        android:textStyle="bold" />
</LinearLayout>
