<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050706">

    <com.lifestreak.wear.workout.WearRunLiveRouteMapView
        android:id="@+id/runRouteMap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/wear_run_map_round"
        android:clipToOutline="true" />

    <TextView
        android:id="@+id/runRouteCoordinate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="6dp"
        android:background="#AA000000"
        android:gravity="center"
        android:maxLines="1"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.12"
        android:paddingStart="7dp"
        android:paddingTop="3dp"
        android:paddingEnd="7dp"
        android:paddingBottom="3dp"
        android:text="내 경로"
        android:textColor="#D7FF3F"
        android:textSize="8sp"
        android:textStyle="bold" />

</FrameLayout>
